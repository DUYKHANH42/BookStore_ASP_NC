@using BookStore.Application.DTO
@model IEnumerable<ReviewDTO>
@{
    ViewData["Title"] = "Quản lý đánh giá";
}

<div class="space-y-8 animate-fadeIn">
    <!-- Filters & Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tighter">Quản lý đánh giá</h2>
            <p class="text-slate-500 font-medium">Lắng nghe phản hồi từ <span class="text-blue-600 font-bold">khách hàng</span> để cải thiện dịch vụ.</p>
        </div>
        
        <div class="flex items-center gap-3 bg-white pl-5 rounded-2xl border border-slate-100 shadow-sm focus-within:ring-4 focus-within:ring-blue-500/10 transition-all">
            <span class="material-symbols-outlined text-slate-400">filter_list</span>
            <select id="productFilter" onchange="filterByProduct(this.value)" 
                    class="bg-transparent border-none outline-none text-[11px] font-black uppercase tracking-widest text-slate-700 pr-12 py-4 cursor-pointer min-w-[240px]">
                <option value="">Tất cả sản phẩm</option>
                @foreach(var p in ViewBag.Products as IEnumerable<ProductDTO>)
                {
                    <option value="@p.Id" selected="@(ViewBag.SelectedProductId == p.Id)">@p.Name</option>
                }
            </select>
        </div>
    </div>

    <!-- Stats Summary -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="glass-card p-6 rounded-[2rem] premium-shadow bg-white flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-blue-50 text-blue-600 flex items-center justify-center">
                <span class="material-symbols-outlined">reviews</span>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Lượt đánh giá</p>
                <p class="text-xl font-black text-slate-900">@Model.Count()</p>
            </div>
        </div>
        <div class="glass-card p-6 rounded-[2rem] premium-shadow bg-white flex items-center gap-4">
            <div class="w-12 h-12 rounded-2xl bg-amber-50 text-amber-600 flex items-center justify-center">
                <span class="material-symbols-outlined">star</span>
            </div>
            <div>
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Trung bình sao</p>
                <p class="text-xl font-black text-slate-900">@(Model.Any() ? Model.Average(x => x.Rating).ToString("F1") : "0") / 5</p>
            </div>
        </div>
        @if (ViewBag.SelectedProductId != null)
        {
            <div class="md:col-span-2 glass-card p-6 rounded-[2rem] premium-shadow bg-blue-600 flex items-center gap-4 text-white">
                <div class="w-12 h-12 rounded-2xl bg-white/20 flex items-center justify-center">
                    <span class="material-symbols-outlined">inventory_2</span>
                </div>
                <div class="min-w-0">
                    <p class="text-[10px] font-black text-white/60 uppercase tracking-widest">Đang xem sản phẩm</p>
                    <p class="text-sm font-black truncate">@((ViewBag.Products as IEnumerable<ProductDTO>).FirstOrDefault(x => x.Id == ViewBag.SelectedProductId)?.Name)</p>
                </div>
            </div>
        }
    </div>

    <!-- Reviews Table -->
    <div class="glass-card rounded-[2.5rem] premium-shadow overflow-hidden bg-white border border-slate-100 mb-20">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="px-8 py-6 text-left text-slate-400 font-black text-[10px] uppercase tracking-widest">Khách hàng</th>
                        <th class="px-6 py-6 text-left text-slate-400 font-black text-[10px] uppercase tracking-widest">Sản phẩm</th>
                        <th class="px-6 py-6 text-left text-slate-400 font-black text-[10px] uppercase tracking-widest">Đánh giá</th>
                        <th class="px-6 py-6 text-left text-slate-400 font-black text-[10px] uppercase tracking-widest">Nội dung & Phản hồi</th>
                        <th class="px-6 py-6 text-center text-slate-400 font-black text-[10px] uppercase tracking-widest">Trạng thái</th>
                        <th class="px-8 py-6 text-right text-slate-400 font-black text-[10px] uppercase tracking-widest">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-8 py-20 text-center">
                                <div class="flex flex-col items-center gap-4">
                                    <span class="material-symbols-outlined text-5xl text-slate-200">reviews</span>
                                    <p class="text-slate-400 font-bold uppercase text-[10px] tracking-widest">Không có đánh giá nào</p>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var r in Model)
                    {
                        <tr class="hover:bg-slate-50/30 transition-all duration-300 group">
                            <td class="px-8 py-8">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 text-white shadow-lg shadow-blue-500/20 flex items-center justify-center font-black text-sm uppercase ring-4 ring-white">
                                        @r.UserName.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="font-black text-slate-900 tracking-tight">@r.UserName</div>
                                        <div class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-0.5">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-8">
                                <div class="font-bold text-slate-700 max-w-[220px] leading-relaxed">@r.ProductName</div>
                            </td>
                            <td class="px-6 py-8">
                                <div class="flex flex-col gap-1">
                                    <div class="flex gap-0.5 text-amber-400">
                                        @for(int i=1; i<=5; i++) {
                                            <span class="material-symbols-outlined text-sm @(i <= r.Rating ? "fill-1" : "opacity-20")">star</span>
                                        }
                                    </div>
                                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-tighter">@r.Rating / 5 sao</span>
                                </div>
                            </td>
                            <td class="px-6 py-8">
                                <div class="max-w-[400px]">
                                    <p class="text-slate-600 font-medium leading-relaxed italic">"@r.Comment"</p>
                                    @if(!string.IsNullOrEmpty(r.AdminReply)) {
                                        <div class="mt-4 p-4 bg-slate-50 rounded-2xl border border-slate-100 flex gap-3 group/reply relative animate-slideIn">
                                            <div class="w-1.5 h-full absolute left-0 top-0 bg-blue-500 rounded-l-2xl"></div>
                                            <span class="material-symbols-outlined text-blue-500 text-lg">reply</span>
                                            <div>
                                                <p class="text-[10px] font-black text-blue-600 uppercase tracking-widest mb-1">Cửa hàng phản hồi</p>
                                                <p class="text-[11px] text-slate-500 font-bold leading-relaxed">@r.AdminReply</p>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-8 text-center">
                                <button onclick="toggleReviewStatus(@r.Id)" 
                                        class="px-5 py-2 rounded-xl font-black text-[10px] uppercase tracking-widest transition-all shadow-sm
                                        @(r.IsActive ? "bg-emerald-50 text-emerald-600 border border-emerald-100 hover:bg-emerald-100" : "bg-rose-50 text-rose-600 border border-rose-100 hover:bg-rose-100")">
                                    @(r.IsActive ? "Hiển thị" : "Đã ẩn")
                                </button>
                            </td>
                            <td class="px-8 py-8 text-right">
                                <div class="flex justify-end gap-2">
                                    <button onclick="openReplyModal(@r.Id, '@r.UserName', '@(r.AdminReply ?? "")')" 
                                            class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white border border-slate-100 text-slate-400 hover:border-blue-600 hover:text-blue-600 hover:bg-blue-50 transition-premium shadow-sm active:scale-90">
                                        <span class="material-symbols-outlined text-xl">chat_bubble</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Reply Modal -->
<div id="replyModal" class="modal-overlay hidden fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[200] flex items-center justify-center p-4" onclick="if(event.target === this) closeReplyModal()">
    <div class="bg-white rounded-[2.5rem] w-full max-w-xl shadow-2xl animate-modalIn flex flex-col overflow-hidden">
        <div class="p-8 border-b border-slate-50 flex justify-between items-center shrink-0">
            <div>
                <h3 class="text-2xl font-black text-slate-900 tracking-tight">Phản hồi đánh giá</h3>
                <p id="replyTarget" class="text-blue-600 text-xs font-bold uppercase tracking-widest mt-1">Gửi tới: ...</p>
            </div>
            <button onclick="closeReplyModal()" class="w-12 h-12 flex items-center justify-center rounded-2xl hover:bg-slate-100 text-slate-400 transition-premium">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-8 space-y-6">
            <textarea id="replyContent" name="reply" rows="4" placeholder="Nhập phản hồi của bạn..." 
                      class="w-full bg-slate-50 border border-slate-100 rounded-3xl px-6 py-4 font-bold text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all resize-none"></textarea>
            <span class="invalid-feedback hidden text-rose-500 text-[10px] font-bold uppercase tracking-widest pl-4"></span>
            
            <button onclick="submitReply()" class="w-full py-4 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-widest shadow-2xl shadow-slate-900/20 hover:bg-black transition-premium active:scale-95 mt-4">
                Gửi phản hồi
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentReviewId = null;

        function filterByProduct(productId) {
            window.location.href = '/Admin/Review?productId=' + productId;
        }

        function openReplyModal(id, userName, currentReply) {
            currentReviewId = id;
            ValidationHelper.clearErrors($('#replyModal'));
            $('#replyTarget').text('Gửi tới: ' + userName);
            $('#replyContent').val(currentReply);
            $('#replyModal').removeClass('hidden').addClass('flex');
        }

        function closeReplyModal() {
            $('#replyModal').addClass('hidden').removeClass('flex');
        }

        function submitReply() {
            const reply = $('#replyContent').val();
            ValidationHelper.clearErrors($('#replyModal'));

            if (!reply) {
                ValidationHelper.showFieldError($('#replyContent'), 'Vui lòng nhập nội dung phản hồi');
                return;
            }

            const btn = $('#replyModal button[onclick="submitReply()"]');
            const originalText = btn.text();
            btn.prop('disabled', true).text('Đang gửi...');

            $.ajax({
                url: '/Admin/Review/Reply',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ reviewId: currentReviewId, reply: reply }),
                success: function (data) {
                    if (data.success) {
                        Swal.fire('Thành công', data.message, 'success').then(() => location.reload());
                    } else {
                        if (data.errors) {
                            ValidationHelper.showErrors($('#replyModal'), data.errors);
                        } else {
                            Swal.fire('Lỗi', data.message, 'error');
                        }
                    }
                },
                complete: function() {
                    btn.prop('disabled', false).text(originalText);
                }
            });
        }

        function toggleReviewStatus(id) {
            Swal.fire({
                title: 'Xác nhận?',
                text: "Bạn muốn thay đổi trạng thái hiển thị của đánh giá này?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Đồng ý',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Admin/Review/ToggleStatus/' + id, function (data) {
                        if (data.success) {
                            toastr.success(data.message);
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            Swal.fire('Lỗi', data.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}

<style>
    .fill-1 { font-variation-settings: 'FILL' 1; }
</style>
