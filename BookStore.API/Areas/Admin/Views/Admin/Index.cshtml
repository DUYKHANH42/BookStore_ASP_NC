@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-8 animate-fadeIn">
    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="glass-card p-8 rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-500 group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-all">
                    <span class="material-symbols-outlined">payments</span>
                </div>
                <span class="text-emerald-500 text-xs font-black">+12.5%</span>
            </div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Tổng doanh thu</p>
            <h3 class="text-2xl font-black text-slate-900">45.280.000đ</h3>
        </div>

        <div class="glass-card p-8 rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-500 group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-rose-50 text-rose-600 rounded-2xl flex items-center justify-center group-hover:bg-rose-600 group-hover:text-white transition-all">
                    <span class="material-symbols-outlined">shopping_cart</span>
                </div>
                <span class="text-emerald-500 text-xs font-black">+8.2%</span>
            </div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Đơn hàng mới</p>
            <h3 class="text-2xl font-black text-slate-900">128</h3>
        </div>

        <div class="glass-card p-8 rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-500 group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-2xl flex items-center justify-center group-hover:bg-amber-600 group-hover:text-white transition-all">
                    <span class="material-symbols-outlined">group</span>
                </div>
                <span class="text-rose-500 text-xs font-black">-2.4%</span>
            </div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Khách hàng mới</p>
            <h3 class="text-2xl font-black text-slate-900">456</h3>
        </div>

        <div class="glass-card p-8 rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-500 group">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center group-hover:bg-emerald-600 group-hover:text-white transition-all">
                    <span class="material-symbols-outlined">library_books</span>
                </div>
                <span class="text-emerald-500 text-xs font-black">Ổn định</span>
            </div>
            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Sách trong kho</p>
            <h3 class="text-2xl font-black text-slate-900">1.240</h3>
        </div>
    </div>

    <!-- Main Section -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Recent Orders -->
        <div class="lg:col-span-2 bg-white rounded-[2.5rem] border border-slate-100 p-10 shadow-sm">
            <div class="flex items-center justify-between mb-8">
                <h3 class="text-xl font-black text-slate-900 tracking-tight">Đơn hàng gần đây</h3>
                <button class="text-xs font-black text-blue-600 uppercase tracking-widest hover:underline">Xem tất cả</button>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-50">
                            <th class="pb-4">Mã ĐH</th>
                            <th class="pb-4">Khách hàng</th>
                            <th class="pb-4">Ngày đặt</th>
                            <th class="pb-4">Tổng tiền</th>
                            <th class="pb-4 text-right">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody class="text-sm font-bold text-slate-600">
                        <tr class="border-b border-slate-50 hover:bg-slate-50 transition-all">
                            <td class="py-4">#ORD-001</td>
                            <td class="py-4">Nguyễn Văn A</td>
                            <td class="py-4 text-slate-400">27/04/2026</td>
                            <td class="py-4 text-slate-900">1.250.000đ</td>
                            <td class="py-4 text-right">
                                <span class="px-3 py-1 bg-emerald-50 text-emerald-600 rounded-full text-[10px] uppercase">Thành công</span>
                            </td>
                        </tr>
                        <tr class="border-b border-slate-50 hover:bg-slate-50 transition-all">
                            <td class="py-4">#ORD-002</td>
                            <td class="py-4">Trần Thị B</td>
                            <td class="py-4 text-slate-400">26/04/2026</td>
                            <td class="py-4 text-slate-900">850.000đ</td>
                            <td class="py-4 text-right">
                                <span class="px-3 py-1 bg-amber-50 text-amber-600 rounded-full text-[10px] uppercase">Chờ xử lý</span>
                            </td>
                        </tr>
                        <tr class="hover:bg-slate-50 transition-all">
                            <td class="py-4">#ORD-003</td>
                            <td class="py-4">Lê Văn C</td>
                            <td class="py-4 text-slate-400">26/04/2026</td>
                            <td class="py-4 text-slate-900">2.100.000đ</td>
                            <td class="py-4 text-right">
                                <span class="px-3 py-1 bg-rose-50 text-rose-600 rounded-full text-[10px] uppercase">Đã hủy</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Inventory Alerts -->
        <div class="bg-slate-900 rounded-[2.5rem] p-10 text-white shadow-2xl shadow-slate-200">
            <h3 class="text-xl font-black mb-8 tracking-tight">Sách sắp hết hàng</h3>
            <div class="space-y-6">
                <div class="flex items-center gap-4 group cursor-pointer">
                    <div class="w-12 h-16 bg-slate-800 rounded-lg overflow-hidden flex-shrink-0">
                        <div class="w-full h-full bg-blue-500 opacity-20"></div>
                    </div>
                    <div>
                        <h4 class="text-sm font-black group-hover:text-blue-400 transition-all line-clamp-1">Kỹ thuật lập trình .NET 8</h4>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-1">Còn lại: 2 cuốn</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 group cursor-pointer">
                    <div class="w-12 h-16 bg-slate-800 rounded-lg overflow-hidden flex-shrink-0">
                        <div class="w-full h-full bg-rose-500 opacity-20"></div>
                    </div>
                    <div>
                        <h4 class="text-sm font-black group-hover:text-blue-400 transition-all line-clamp-1">Thiết kế UI/UX hiện đại</h4>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-1">Còn lại: 0 cuốn</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 group cursor-pointer">
                    <div class="w-12 h-16 bg-slate-800 rounded-lg overflow-hidden flex-shrink-0">
                        <div class="w-full h-full bg-emerald-500 opacity-20"></div>
                    </div>
                    <div>
                        <h4 class="text-sm font-black group-hover:text-blue-400 transition-all line-clamp-1">Lịch sử văn minh nhân loại</h4>
                        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-1">Còn lại: 5 cuốn</p>
                    </div>
                </div>
            </div>
            <button class="w-full mt-10 py-4 bg-white/10 hover:bg-white/20 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all border border-white/10">
                Xem tất cả kho hàng
            </button>
        </div>
    </div>
</div>

<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeIn {
        animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>
