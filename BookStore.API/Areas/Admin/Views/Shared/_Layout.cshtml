<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Lumen</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .sidebar-link.active { background-color: #2563eb; color: white; }
        .glass-card { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.3); }
        
        /* Custom scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">
    <div class="flex min-h-screen">
        <!-- Sidebar -->
        <aside class="w-72 bg-slate-900 text-white flex-shrink-0 flex flex-col sticky top-0 h-screen">
            <div class="p-8 border-b border-slate-800">
                <h1 class="text-2xl font-black tracking-tighter">LUMEN <span class="text-blue-500">ADMIN</span></h1>
            </div>
            
            <nav class="flex-1 p-6 space-y-2 overflow-y-auto">
                <a asp-area="Admin" asp-controller="Admin" asp-action="Index" 
                   class="flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-slate-800 transition-all font-bold text-sm @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "bg-blue-600 text-white" : "text-slate-400 hover:text-white")">
                    <span class="material-symbols-outlined">dashboard</span> Dashboard
                </a>

                <div class="pt-4 pb-2">
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 px-4">Quản lý kho</p>
                </div>
                <a href="#" class="flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-slate-800 transition-all font-bold text-sm text-slate-400 hover:text-white">
                    <span class="material-symbols-outlined">menu_book</span> Quản lý sách
                </a>
                <a href="#" class="flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-slate-800 transition-all font-bold text-sm text-slate-400 hover:text-white">
                    <span class="material-symbols-outlined">category</span> Danh mục
                </a>

                <div class="pt-4 pb-2">
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 px-4">Kinh doanh</p>
                </div>
                <a href="#" class="flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-slate-800 transition-all font-bold text-sm text-slate-400 hover:text-white">
                    <span class="material-symbols-outlined">shopping_bag</span> Đơn hàng
                </a>
                <a href="#" class="flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-slate-800 transition-all font-bold text-sm text-slate-400 hover:text-white">
                    <span class="material-symbols-outlined">group</span> Khách hàng
                </a>

                <div class="pt-4 pb-2">
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-500 px-4">Cài đặt</p>
                </div>
                <a href="#" class="flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-slate-800 transition-all font-bold text-sm text-slate-400 hover:text-white">
                    <span class="material-symbols-outlined">settings</span> Cấu hình
                </a>
            </nav>

            <div class="p-6 border-t border-slate-800">
                <a href="/" class="flex items-center gap-4 px-4 py-3 rounded-2xl hover:bg-rose-600 transition-all font-bold text-sm text-slate-400 hover:text-white">
                    <span class="material-symbols-outlined">logout</span> Quay về Client
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col">
            <!-- Header -->
            <header class="h-20 bg-white border-b border-slate-100 flex items-center justify-between px-10 sticky top-0 z-50">
                <div class="flex items-center gap-4">
                    <button class="lg:hidden p-2 hover:bg-slate-50 rounded-xl">
                        <span class="material-symbols-outlined">menu</span>
                    </button>
                    <div class="flex items-center gap-2 text-xs font-bold text-slate-400 uppercase tracking-widest">
                        <span>Admin</span>
                        <span class="material-symbols-outlined text-sm">chevron_right</span>
                        <span class="text-slate-900">@ViewData["Title"]</span>
                    </div>
                </div>

                <div class="flex items-center gap-6">
                    <!-- Notifications -->
                    <button class="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-all relative">
                        <span class="material-symbols-outlined">notifications</span>
                        <span class="absolute top-2 right-2 w-2 h-2 bg-rose-500 rounded-full border-2 border-white"></span>
                    </button>

                    <div class="h-8 w-[1px] bg-slate-100"></div>

                    <!-- User Profile -->
                    <div class="relative group">
                        <button class="flex items-center gap-3 p-2 hover:bg-slate-50 rounded-2xl transition-all">
                            <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-black shadow-lg shadow-blue-200">A</div>
                            <div class="text-left hidden sm:block">
                                <p class="text-xs font-black text-slate-900 leading-none mb-1">Administrator</p>
                                <p class="text-[10px] font-bold text-slate-400">admin@lumen.com</p>
                            </div>
                            <span class="material-symbols-outlined text-slate-400">expand_more</span>
                        </button>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <main class="p-10 flex-1">
                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="p-10 border-t border-slate-100 text-center">
                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em]">© 2026 Lumen BookStore • Admin Control Panel v1.0</p>
            </footer>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
