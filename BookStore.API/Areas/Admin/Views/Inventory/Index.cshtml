@using BookStore.Application.DTO
@model PagedResultDTO<InventoryReceiptDTO>
@{
    ViewData["Title"] = "Quản lý phiếu nhập kho";
}

@section Styles {
    <link rel="stylesheet" href="~/admin/css/inventory-management.css" />
}

<div class="inventory-container space-y-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h2 class="text-3xl font-black text-slate-900 tracking-tighter">Chứng từ nhập kho</h2>
            <p class="text-slate-500 font-medium">Danh sách các phiếu nhập hàng chính quy từ nhà cung cấp.</p>
        </div>
        <div class="flex gap-4">
            <a href="@Url.Action("History")" class="flex items-center gap-3 px-6 py-4 bg-white border border-slate-200 text-slate-600 rounded-[1.25rem] font-bold text-sm hover:bg-slate-50 transition-premium">
                <span class="material-symbols-outlined">history</span> Xem nhật ký biến động
            </a>
            <a href="@Url.Action("Import")" class="flex items-center gap-3 px-8 py-4 bg-blue-600 text-white rounded-[1.25rem] font-black text-sm shadow-xl shadow-blue-600/20 hover:bg-blue-700 transition-premium active:scale-95">
                <span class="material-symbols-outlined">add_box</span> Lập phiếu nhập mới
            </a>
        </div>
    </div>

    <!-- Receipts Table -->
    <div class="glass-card rounded-[2.5rem] overflow-hidden bg-white border border-slate-100 premium-shadow">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 w-full text-sm">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="ps-8 py-6 text-slate-400 font-black text-[10px] uppercase tracking-widest">Mã Phiếu</th>
                        <th class="text-slate-400 font-black text-[10px] uppercase tracking-widest">Nhà cung cấp</th>
                        <th class="text-slate-400 font-black text-[10px] uppercase tracking-widest">Ngày nhập</th>
                        <th class="text-slate-400 font-black text-[10px] uppercase tracking-widest text-center">Tổng tiền</th>
                        <th class="text-slate-400 font-black text-[10px] uppercase tracking-widest">Trạng thái</th>
                        <th class="text-end pe-8 text-slate-400 font-black text-[10px] uppercase tracking-widest">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var r in Model.Items)
                    {
                        <tr class="hover:bg-slate-50/30 transition-colors">
                            <td class="ps-8 py-6">
                                <span class="font-black text-slate-900 tracking-tighter">#@r.Id</span>
                            </td>
                            <td>
                                <div class="text-slate-900 font-bold">@r.SupplierName</div>
                            </td>
                            <td>
                                <div class="text-slate-600 font-medium">@r.ReceivedDate.ToString("dd/MM/yyyy")</div>
                                <div class="text-[10px] text-slate-400 font-bold">@r.ReceivedDate.ToString("HH:mm")</div>
                            </td>
                            <td class="text-center">
                                <span class="text-blue-600 font-black">@r.TotalAmount.ToString("N0")₫</span>
                            </td>
                            <td>
                                <span class="px-4 py-1.5 bg-emerald-50 text-emerald-600 rounded-xl font-black text-[9px] uppercase tracking-widest border border-emerald-100">@r.Status</span>
                            </td>
                            <td class="text-end pe-8">
                                <div class="flex justify-end gap-2">
                                    <button onclick="viewReceiptDetails(@r.Id)" class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-400 hover:bg-blue-600 hover:text-white transition-premium shadow-sm">
                                        <span class="material-symbols-outlined text-xl">visibility</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="px-8 py-6 border-t border-slate-50 bg-slate-50/30 flex items-center justify-between">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
                Hiển thị <span class="text-slate-900">@Model.Items.Count()</span> trên <span class="text-slate-900">@Model.TotalItems</span> chứng từ
            </p>
            
            <div class="flex items-center gap-2">
                @if (Model.CurrentPage > 1)
                {
                    <a href="@Url.Action("Index", new { page = Model.CurrentPage - 1 })" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-slate-100 text-slate-400 hover:text-blue-600 transition-premium shadow-sm">
                        <span class="material-symbols-outlined">chevron_left</span>
                    </a>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 2 && i <= Model.CurrentPage + 2))
                    {
                        <a href="@Url.Action("Index", new { page = i })" 
                           class="w-10 h-10 flex items-center justify-center rounded-xl font-black text-xs transition-premium shadow-sm
                           @(i == Model.CurrentPage ? "bg-blue-600 text-white shadow-blue-500/20" : "bg-white border border-slate-100 text-slate-400 hover:border-blue-600 hover:text-blue-600")">
                            @i
                        </a>
                    }
                    else if (i == 2 || i == Model.TotalPages - 1)
                    {
                        <span class="px-1 text-slate-300">...</span>
                    }
                }

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a href="@Url.Action("Index", new { page = Model.CurrentPage + 1 })" class="w-10 h-10 flex items-center justify-center rounded-xl bg-white border border-slate-100 text-slate-400 hover:text-blue-600 transition-premium shadow-sm">
                        <span class="material-symbols-outlined">chevron_right</span>
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal xem chi tiết phiếu nhập -->
<div id="receiptModal" class="fixed inset-0 z-[200] hidden bg-slate-900/60 backdrop-blur-sm items-center justify-center p-4" onclick="if(event.target === this) closeReceiptModal()">
    <div class="modal-content bg-white rounded-[2.5rem] w-full max-w-4xl overflow-hidden shadow-2xl">
        <div id="receiptModalBody"></div>
    </div>
</div>

@section Scripts {
    <script>
        function viewReceiptDetails(id) {
            $('#receiptModal').removeClass('hidden').addClass('flex');
            $('#receiptModalBody').html('<div class="p-20 text-center font-bold text-slate-400">Đang tải chi tiết phiếu...</div>');
            
            $.get('/Admin/Inventory/GetReceiptDetails', { id: id }, function (data) {
                $('#receiptModalBody').html(data);
            });
        }
        function closeReceiptModal() {
            $('#receiptModal').addClass('hidden').removeClass('flex');
        }
    </script>
}
