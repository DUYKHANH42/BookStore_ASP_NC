@using BookStore.Application.DTO
@{
    ViewData["Title"] = "Nhập hàng & Khởi tạo";
    var categories = ViewBag.Categories as IEnumerable<CategoryDTO>;
    var suppliers = ViewBag.Suppliers as IEnumerable<BookStore.Domain.Entities.Supplier>;
}

@section Styles {
    <link rel="stylesheet" href="~/admin/css/inventory-management.css" />
}

<div class="inventory-container max-w-4xl mx-auto space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
            <a href="@Url.Action("Index")" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white border border-slate-100 text-slate-400 hover:text-slate-900 transition-premium">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <div>
                <h2 class="text-3xl font-black text-slate-900 tracking-tighter">Nhập hàng mới</h2>
                <p class="text-slate-500 font-medium text-sm">Quản lý nhập kho qua Chứng từ & Khởi tạo sản phẩm</p>
            </div>
        </div>
    </div>

    <div class="import-card p-10">
        <form id="importStockForm" enctype="multipart/form-data" class="space-y-8">
            <!-- Bước 1: Chứng từ & SKU -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-2">
                    <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Nhà cung cấp</label>
                    <select name="SupplierId" class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-bold text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all appearance-none cursor-pointer">
                        @if (suppliers != null)
                        {
                            foreach(var s in suppliers) { <option value="@s.Id">@s.Name</option> }
                        }
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Mã SKU định danh</label>
                    <div class="sku-input-wrapper">
                        <input type="text" id="skuInput" name="SKU" required placeholder="Gõ hoặc quét mã SKU..." 
                               class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-black text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all shadow-sm">
                        <div class="sku-status-icon"></div>
                    </div>
                </div>
            </div>

            <!-- Bước 2: Số lượng & Giá -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="space-y-2">
                    <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Số lượng nhập</label>
                    <input type="number" name="QuantityToImport" required min="1" value="1"
                           class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-black text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all shadow-sm">
                </div>
                <div class="space-y-2">
                    <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Giá nhập (₫)</label>
                    <input type="number" name="ImportPrice" required min="0" placeholder="0"
                           class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-black text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all shadow-sm">
                </div>
                <div class="space-y-2">
                    <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Ghi chú phiếu</label>
                    <input type="text" name="Notes" placeholder="VD: Nhập đợt 1..."
                           class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-bold text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all shadow-sm">
                </div>
            </div>

            <!-- Bước 3: Thông tin sản phẩm (Expandable) -->
            <div class="new-product-section">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center">
                        <span class="material-symbols-outlined">new_releases</span>
                    </div>
                    <div>
                        <h5 class="text-slate-900 font-black text-sm mb-0">Thông tin chi tiết sản phẩm</h5>
                        <p class="text-slate-400 text-[10px] font-bold uppercase tracking-widest">Khởi tạo hoặc cập nhật thông tin bán hàng</p>
                    </div>
                </div>

                <div id="productInfoAlert" class="hidden mb-6 p-4 bg-emerald-50 rounded-2xl border border-emerald-100 flex items-center gap-3">
                    <span class="material-symbols-outlined text-emerald-500">info</span>
                    <span class="text-sm text-emerald-700 font-bold uppercase tracking-tight">Hệ thống đã nhận diện: <span class="p-name underline"></span></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2 md:col-span-2">
                        <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Tên sản phẩm/Sách</label>
                        <input type="text" id="nameInput" name="Name" placeholder="Nhập tên đầy đủ..." 
                               class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-bold text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Thương hiệu/Tác giả</label>
                        <input type="text" id="brandInput" name="Brand" placeholder="VD: Nhà xuất bản Trẻ..." 
                               class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-bold text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all">
                    </div>
                    <div class="space-y-2">
                        <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Giá bán niêm yết (₫)</label>
                        <input type="number" id="sellingPriceInput" name="SellingPrice" placeholder="0" 
                               class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-black text-blue-600 outline-none focus:border-blue-600 focus:bg-white transition-all">
                    </div>

                    <div class="space-y-2">
                        <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Danh mục chính</label>
                        <select id="categorySelect" name="CategoryId" class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-bold text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all appearance-none cursor-pointer">
                            <option value="">-- Chọn danh mục --</option>
                            @if (categories != null)
                            {
                                foreach(var cat in categories) { <option value="@cat.Id">@cat.Name</option> }
                            }
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Danh mục con</label>
                        <select id="subCategorySelect" name="SubCategoryId" class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-bold text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all appearance-none cursor-pointer">
                            <option value="">-- Chọn danh mục con --</option>
                        </select>
                    </div>

                    <div class="space-y-2 md:col-span-2">
                        <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Mô tả sản phẩm</label>
                        <textarea id="descriptionInput" name="Description" rows="3" placeholder="Thông tin chi tiết về nội dung sách, chất lượng..." 
                                  class="w-full bg-slate-50 border border-slate-100 rounded-2xl px-6 py-4 font-medium text-slate-700 outline-none focus:border-blue-600 focus:bg-white transition-all"></textarea>
                    </div>

                    <div class="space-y-2 md:col-span-2">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="space-y-2">
                                <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Hình ảnh đại diện (Ảnh chính)</label>
                                <div class="trigger-image-input flex flex-col items-center gap-4 p-6 bg-slate-50 rounded-2xl border border-slate-100 border-dashed hover:border-blue-400 hover:bg-blue-50/30 transition-all cursor-pointer group">
                                    <div id="imagePreview" class="w-full h-32 rounded-2xl bg-white shadow-lg flex items-center justify-center overflow-hidden border border-white group-hover:scale-105 transition-all">
                                        <span class="material-symbols-outlined text-slate-200 text-4xl">add_photo_alternate</span>
                                    </div>
                                    <input type="file" name="ImageFile" id="imageInput" accept="image/*" class="hidden">
                                    <button type="button" class="px-4 py-2 bg-blue-600 text-white rounded-xl font-bold text-[10px] uppercase tracking-widest shadow-lg shadow-blue-600/20">Chọn ảnh chính</button>
                                </div>
                            </div>
                            
                            <div class="space-y-2">
                                <label class="text-[11px] font-black uppercase tracking-widest text-slate-400 px-1">Bộ sưu tập ảnh phụ (Tùy chọn)</label>
                                <div class="trigger-gallery-input flex flex-col items-center gap-4 p-6 bg-slate-50 rounded-2xl border border-slate-100 border-dashed hover:border-emerald-400 hover:bg-emerald-50/30 transition-all cursor-pointer group">
                                    <div class="w-full h-32 rounded-2xl bg-white shadow-lg flex items-center justify-center border border-white group-hover:scale-105 transition-all overflow-y-auto p-2">
                                        <div id="galleryPreview" class="flex flex-wrap gap-2 justify-center">
                                            <span class="material-symbols-outlined text-slate-200 text-4xl mt-6">collections</span>
                                        </div>
                                    </div>
                                    <input type="file" name="AdditionalImageFiles" id="additionalImagesInput" accept="image/*" multiple class="hidden">
                                    <button type="button" class="px-4 py-2 bg-emerald-600 text-white rounded-xl font-bold text-[10px] uppercase tracking-widest shadow-lg shadow-emerald-600/20">Chọn nhiều ảnh</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="pt-10 flex gap-4 border-t border-slate-50">
                <button type="submit" class="flex-1 py-5 bg-slate-900 text-white rounded-[1.5rem] font-black text-sm uppercase tracking-widest hover:bg-black transition-premium shadow-2xl shadow-slate-900/20 active:scale-95">
                    Xác nhận Nhập kho & Lưu thông tin
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/admin/js/inventory-management.js"></script>
}
